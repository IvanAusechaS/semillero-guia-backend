# =================================
# SEMILLERO GUIA BACKEND - ENVIRONMENT VARIABLES
# =================================

# ------ SERVIDOR ------
NODE_ENV=production
PORT=4000

# ------ BASE DE DATOS MONGODB ------
# MongoDB Atlas Connection String (Reemplazar con tu cluster)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/semillero-guia?retryWrites=true&w=majority

# Nombre de la base de datos
DATABASE_NAME=semillero-guia

# ------ AUTENTICACIÓN JWT ------
# Clave secreta para JWT (DEBE ser un string largo y seguro en producción)
JWT_SECRET=your-super-secure-jwt-secret-key-here-make-it-long-and-random

# Tiempo de expiración del token (ejemplo: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# Cookie expiration time in milliseconds (7 days = 7 * 24 * 60 * 60 * 1000)
JWT_COOKIE_EXPIRES_IN=604800000

# ------ CORS Y FRONTEND ------
# URLs permitidas para CORS (separadas por coma)
FRONTEND_URL=http://localhost:3000,https://your-frontend-domain.com

# ------ SEGURIDAD ------
# Rate limiting - máximo de requests por ventana de tiempo
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ------ ARCHIVOS Y UPLOADS ------
# Tamaño máximo de archivos en bytes (10MB = 10 * 1024 * 1024)
MAX_FILE_SIZE=10485760

# Directorio para almacenar archivos subidos
UPLOAD_DIR=uploads

# Tipos de archivos permitidos
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/gif,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ------ EMAIL (Para notificaciones) ------
EMAIL_FROM=semillero.guia@correounivalle.edu.co
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# ------ CONFIGURACIÓN DE DESARROLLO ------
# Habilitar logs detallados en desarrollo
DEBUG_MODE=false

# Habilitar mongoDB debug logs
MONGODB_DEBUG=false

# =================================
# INSTRUCCIONES PARA HEROKU:
# =================================
# 1. No subir este archivo a GitHub (está en .gitignore)
# 2. Configurar las variables en Heroku Dashboard:
#    Settings -> Config Vars
# 3. O usar Heroku CLI:
#    heroku config:set VARIABLE_NAME=value
# =================================

# EJEMPLO DE MONGODB_URI PARA HEROKU:
# mongodb+srv://semillero_user:Tu_Password_Segura@cluster0.xxxxx.mongodb.net/semillero-guia?retryWrites=true&w=majority

# EJEMPLO DE JWT_SECRET PARA HEROKU:
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"